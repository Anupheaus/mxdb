{
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "isolatedModules": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "allowJs": true,
    "skipLibCheck": true,
    "noErrorTruncation": true,
    "lib": [
      "DOM",
      "WebWorker",
      "ES2022",
      "ESNext.AsyncIterable"
    ],
    "target": "ES2022",
    "sourceMap": true,
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "paths": {
      "@anupheaus/common": [
        "../common/src"
      ],
      "@anupheaus/react-ui": [
        "../react-ui/src"
      ],
      "@anupheaus/nexus/server": [
        "../nexus/src/server"
      ],
      "@anupheaus/nexus/client": [
        "../nexus/src/client"
      ],
      "@anupheaus/nexus/common": [
        "../nexus/src/common"
      ],
      "@anupheaus/nexus/common/auth": [
        "../nexus/src/common/auth"
      ]
    }
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "moduleResolution": "node"
    }
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
